{
  "rules": [
    {
      "id": "config_request_to_service",
      "description": "Any member startup → ConfigService",
      "event": "agent_config_requested",
      "from": "*",
      "to": "SYSTM-ALL___-GA-CFGSV",
      "priority": 1
    },
    {
      "id": "ec_config_request_to_service",
      "description": "EC startup → ConfigService",
      "event": "ec_config_requested",
      "from": "*-*-EC-*",
      "to": "SYSTM-ALL___-GA-CFGSV",
      "priority": 1
    },
    {
      "id": "repo_request_to_service",
      "description": "Any member DB request → RepositoryService",
      "event": "repo_request",
      "from": "*",
      "to": "SYSTM-ALL___-GA-REPO",
      "priority": 2
    },
    {
      "id": "m5_candle_to_data",
      "description": "M5 candle update → DataContainer",
      "event": "m5_candle_update",
      "from": "*-*-AD-ADPT",
      "to": "SYSTM-ALL___-GA-DATA",
      "priority": 10
    },
    {
      "id": "candle_gap_to_data",
      "description": "Gap detected → DataContainer",
      "event": "candle_gap_detected",
      "from": "*-*-AD-ADPT",
      "to": "SYSTM-ALL___-GA-DATA",
      "priority": 10
    },
    {
      "id": "candle_data_bulk_to_data",
      "description": "Bulk candle data from broker → DataContainer",
      "event": "candle_data_bulk",
      "from": "*-*-AD-ADPT",
      "to": "SYSTM-ALL___-GA-DATA",
      "priority": 10
    },
    {
      "id": "account_status_to_data",
      "description": "Account status from broker → DataContainer (persists to DB)",
      "event": "account_status_updated",
      "from": "*-*-AD-ADPT",
      "to": "SYSTM-ALL___-GA-DATA",
      "priority": 10
    },
    {
      "id": "m5_candle_trigger_to_matching_aa",
      "description": "Delayed M5 candle trigger → matching AA (same broker+pair)",
      "event": "m5_candle_trigger",
      "from": "*-*-AD-ADPT",
      "to": "{sender.broker}-{sender.pair}-AA-*",
      "priority": 11
    },
    {
      "id": "m5_candle_trigger_to_echo_ec",
      "description": "M5 candle trigger → ECHO EC only (test entity)",
      "event": "m5_candle_trigger",
      "from": "*-*-AD-ADPT",
      "to": "GLOBL-ALL___-EC-ECHO",
      "priority": 12
    },
    {
      "id": "m5_candle_trigger_to_trailing_sl_ec",
      "description": "M5 candle trigger → Trailing SL EC (pair-matched)",
      "event": "m5_candle_trigger",
      "from": "*-*-AD-ADPT",
      "to": "{sender.broker}-{sender.pair}-EC-TRSLF",
      "priority": 12,
      "comment": "An EC with the name following the name pattern: {sender.broker}-{sender.pair}-EC-TRSLF will get any M5 candle of the selected {sender.pair}."
    },
    {
      "id": "aa_signal_to_ec",
      "description": "AA signal → pair-matched EC relay",
      "event": "signal_generated",
      "from": "*-*-AA-*",
      "to": "{sender.broker}-{sender.pair}-EC-RELAY",
      "priority": 20
    },
    {
      "id": "aa_analysis_to_ec",
      "description": "AA analysis result → pair-matched EC relay",
      "event": "analysis_result",
      "from": "*-*-AA-*",
      "to": "{sender.broker}-{sender.pair}-EC-RELAY",
      "priority": 20
    },
    {
      "id": "ec_relay_to_ba",
      "description": "EC relay output → BA of the same broker",
      "event": "ec_output",
      "from": "*-*-EC-RELAY",
      "to": "{sender.broker}-ALL___-BA-*",
      "priority": 20
    },
    {
      "id": "ba_approved_to_aa",
      "description": "BA approval → all AAs of the same broker",
      "event": "signal_approved",
      "from": "*-ALL___-BA-*",
      "to": "{sender.broker}-*-AA-*",
      "priority": 20
    },
    {
      "id": "ba_rejected_to_aa",
      "description": "BA rejection → all AAs of the same broker",
      "event": "signal_rejected",
      "from": "*-ALL___-BA-*",
      "to": "{sender.broker}-*-AA-*",
      "priority": 20
    },
    {
      "id": "ba_prompt_update_to_aa",
      "description": "BA prompt update → all AAs of the same broker",
      "event": "prompt_updated",
      "from": "*-ALL___-BA-*",
      "to": "{sender.broker}-*-AA-*",
      "priority": 20
    },
    {
      "id": "analysis_requested_to_ga",
      "description": "Analysis request → all Global Agents",
      "event": "analysis_requested",
      "from": "*",
      "to": "GLOBL-ALL___-GA-*",
      "priority": 20
    },
    {
      "id": "ga_prompt_broadcast",
      "description": "GA prompt update → all agents",
      "event": "prompt_updated",
      "from": "GLOBL-*-GA-*",
      "to": "*-*-*-*",
      "priority": 25
    },
    {
      "id": "risk_breach_to_ba",
      "description": "Risk breach → BA of the same broker",
      "event": "risk_breach",
      "from": "*",
      "to": "{sender.broker}-ALL___-BA-*",
      "priority": 25
    },
    {
      "id": "ob_sync_to_ba",
      "description": "Order-book sync discrepancy → BA of the same broker",
      "event": "order_book_sync_discrepancy",
      "from": "*-*-AD-ADPT",
      "to": "{sender.broker}-ALL___-BA-*",
      "priority": 30
    },
    {
      "id": "ob_close_reasoning_to_ba",
      "description": "Order-book close reasoning → BA",
      "event": "order_book_close_reasoning",
      "from": "*",
      "to": "{sender.broker}-ALL___-BA-*",
      "priority": 30
    },
    {
      "id": "position_closed_to_ba",
      "description": "Position closed → BA of the same broker",
      "event": "position_closed",
      "from": "*-*-AD-ADPT",
      "to": "{sender.broker}-ALL___-BA-*",
      "priority": 30
    },
    {
      "id": "order_placed_to_ba",
      "description": "Order placed confirmation → BA",
      "event": "order_placed",
      "from": "*-*-AD-ADPT",
      "to": "{sender.broker}-ALL___-BA-*",
      "priority": 30
    },
    {
      "id": "optimization_complete_to_ga",
      "description": "Optimization complete → Global Agents",
      "event": "optimization_complete",
      "from": "*",
      "to": "GLOBL-ALL___-GA-*",
      "priority": 40
    }
  ]
}
