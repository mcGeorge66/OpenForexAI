    {
      "id": "snip_assembly_cancel",
      "name": "Cancel cycle",
      "version": "1",
      "tags": "",
      "description": "Assembly script — abort the snapshot cycle (e.g. outside trading hours). Set cancel_reason to explain why.",
      "code": "# Set cancel = True to abort this snapshot cycle.\ncancel = True\ncancel_reason = \"Condition not met\""
    },
    {
      "id": "snip_calc_rsi_state",
      "name": "RSI State",
      "version": "1",
      "tags": "SnapshotCalc",
      "description": "Classifies RSI into oversold/overbought levels and produces a long/short conflict signal. Reads an RSI indicator tool block. Outputs: value, direction, level, long_timing, short_timing, conflict{long, short}.",
      "code": "# === KONFIGURATION ===\n# Beispiel: rsi_key = \"rsi_primary\"  wenn der calculate_indicator Block so heisst\nrsi_key          = \"rsi_primary\"  # calculate_indicator Block RSI\nlong_hard_below  = 30.0           # Unter diesem Wert: hard_conflict für Long (überkauft)\nlong_soft_below  = 40.0           # Unter diesem Wert: soft_conflict für Long\nshort_soft_above = 60.0           # Über diesem Wert: soft_conflict für Short\nshort_hard_above = 70.0           # Über diesem Wert: hard_conflict für Short\n                                  # Beispiel: aggressiver  → long_soft_below = 35, short_soft_above = 65\n\n# === LOGIK (nur bei Bedarf anpassen) ===\nrsi_data = tool_outputs.get(rsi_key) or {}\nrsi_value = None\nif isinstance(rsi_data, dict) and rsi_data.get(\"latest\") is not None:\n    try: rsi_value = float(rsi_data[\"latest\"])\n    except (TypeError, ValueError): pass\n\ndirection = str(rsi_data.get(\"direction\") or \"flat\") if isinstance(rsi_data, dict) else \"flat\"\n\nif rsi_value is None:\n    result = {\"value\": None, \"direction\": direction, \"level\": \"unknown\",\n              \"conflict\": {\"long\": \"none\", \"short\": \"none\"}}\nelse:\n    v = rsi_value\n    if v <= long_hard_below:\n        level          = \"extreme_oversold\"\n        long_timing    = \"early_rebound_possible_but_unconfirmed\"\n        short_timing   = \"blocked_late_short_risk\"\n        long_conflict  = \"hard_conflict\"\n        short_conflict = \"late_entry_risk\"\n    elif v < long_soft_below:\n        level          = \"oversold\"\n        long_timing    = \"rebound_watch\"\n        short_timing   = \"caution_late_short\"\n        long_conflict  = \"soft_conflict\" if direction == \"falling\" else \"watch\"\n        short_conflict = \"late_entry_risk\"\n    elif v >= short_hard_above:\n        level          = \"extreme_overbought\"\n        long_timing    = \"blocked_late_long_risk\"\n        short_timing   = \"early_reversal_possible_but_unconfirmed\"\n        long_conflict  = \"late_entry_risk\"\n        short_conflict = \"hard_conflict\"\n    elif v > short_soft_above:\n        level          = \"overbought\"\n        long_timing    = \"caution_late_long\"\n        short_timing   = \"reversal_watch\"\n        long_conflict  = \"late_entry_risk\"\n        short_conflict = \"soft_conflict\" if direction == \"rising\" else \"watch\"\n    else:\n        level          = \"neutral_band\"\n        long_timing    = \"neutral\"\n        short_timing   = \"neutral\"\n        long_conflict  = \"none\"\n        short_conflict = \"none\"\n\n    result = {\n        \"value\":        round(rsi_value, 3),\n        \"direction\":    direction,\n        \"level\":        level,\n        \"long_timing\":  long_timing,\n        \"short_timing\": short_timing,\n        \"conflict\":     {\"long\": long_conflict, \"short\": short_conflict},\n    }\n"
    },
    {
      "id": "snip_calc_trend",
      "name": "Trend Analysis",
      "version": "1",
      "tags": "SnapshotCalc",
      "description": "EMA-based trend direction and state. Reads ema_fast, ema_slow and current candles from tool_outputs. Outputs: direction, h1_trend, trend_state, ema values, slopes, price position.",
      "code": "# === KONFIGURATION = TREND V1 ===\n# output_key deiner Tool-Blöcke — muss mit den Block-IDs in \"Tool Blocks\" übereinstimmen\n# Beispiel: candles_key = \"m5_recent\"  wenn der get_candles Block so heisst\ncandles_key  = \"h1_recent\"   # get_candles Block (für aktuellen Kurs)\nema_fast_key = \"ema_fast\"    # calculate_indicator Block EMA Fast  (z.B. EMA 20)\nema_slow_key = \"ema_slow\"    # calculate_indicator Block EMA Slow  (z.B. EMA 50)\n\n# === LOGIK (nur bei Bedarf anpassen) ===\nema_fast_data = tool_outputs.get(ema_fast_key) or {}\nema_slow_data = tool_outputs.get(ema_slow_key) or {}\ncandles_data  = tool_outputs.get(candles_key)  or []\n\nema_fast_val = None\nema_slow_val = None\nif isinstance(ema_fast_data, dict) and ema_fast_data.get(\"latest\") is not None:\n    try: ema_fast_val = float(ema_fast_data[\"latest\"])\n    except (TypeError, ValueError): pass\nif isinstance(ema_slow_data, dict) and ema_slow_data.get(\"latest\") is not None:\n    try: ema_slow_val = float(ema_slow_data[\"latest\"])\n    except (TypeError, ValueError): pass\n\nema_fast_dir = str(ema_fast_data.get(\"direction\") or \"flat\") if isinstance(ema_fast_data, dict) else \"flat\"\nema_slow_dir = str(ema_slow_data.get(\"direction\") or \"flat\") if isinstance(ema_slow_data, dict) else \"flat\"\n\ncurrent_price = None\nif isinstance(candles_data, list) and candles_data:\n    last = candles_data[-1]\n    if isinstance(last, dict) and last.get(\"close\") is not None:\n        try: current_price = float(last[\"close\"])\n        except (TypeError, ValueError): pass\n\nh1_trend = \"neutral\"\nif ema_fast_val is not None and ema_slow_val is not None:\n    if ema_fast_val > ema_slow_val:   h1_trend = \"bullish\"\n    elif ema_fast_val < ema_slow_val: h1_trend = \"bearish\"\n\ndef _pvl(price, level):\n    if price is None or level is None: return \"unknown\"\n    if price > level + 1e-9: return \"above\"\n    if price < level - 1e-9: return \"below\"\n    return \"at\"\n\npf = _pvl(current_price, ema_fast_val)\nps = _pvl(current_price, ema_slow_val)\n\nif h1_trend == \"bullish\":\n    trend_state = \"confirmed_bullish\"  if pf == \"above\" and ps == \"above\" else \"early_bullish_recovery\"\nelif h1_trend == \"bearish\":\n    trend_state = \"confirmed_bearish\"  if pf == \"below\" and ps == \"below\" else \"early_bearish_breakdown\"\nelse:\n    trend_state = \"neutral\"\n\nresult = {\n    \"direction\":         \"long\" if h1_trend == \"bullish\" else \"short\" if h1_trend == \"bearish\" else \"neutral\",\n    \"h1_trend\":          h1_trend,\n    \"ema_fast\":          round(ema_fast_val, 6) if ema_fast_val is not None else None,\n    \"ema_fast_slope\":    ema_fast_dir,\n    \"ema_slow\":          round(ema_slow_val, 6) if ema_slow_val is not None else None,\n    \"ema_slow_slope\":    ema_slow_dir,\n    \"price_vs_ema_fast\": pf,\n    \"price_vs_ema_slow\": ps,\n    \"trend_state\":       trend_state,\n}\nif current_price is not None:\n    result[\"current_price\"] = round(current_price, 6)\n"
    },
    {
      "id": "snip_calc_micro_sr",
      "name": "Micro S/R",
      "version": "1",
      "tags": "SnapshotCalc",
      "description": "Nearest support and resistance from recent candle highs/lows. Computes ATR-based gate pass flags. Outputs: nearest_resistance, nearest_support, sr_gate_passed_long/short, distance_to_*_atr.",
      "code": "# === KONFIGURATION ===\n# Beispiel: candles_key = \"m5_recent\"  — mindestens 'lookback' Kerzen konfigurieren\ncandles_key  = \"m5_recent\"   # get_candles Block (mindestens lookback Kerzen nötig)\natr_key      = \"atr_primary\" # calculate_indicator Block ATR\nlookback     = 12            # Anzahl Kerzen für S/R-Berechnung (Standard: 12, min: 12)\nsr_threshold = 0.50          # Mindestabstand in ATR-Einheiten für Gate-Pass (Standard: 0.50)\n\n# === LOGIK (nur bei Bedarf anpassen) ===\ncandles_data = tool_outputs.get(candles_key) or []\natr_data     = tool_outputs.get(atr_key) or {}\n\ncandles = []\nif isinstance(candles_data, list):\n    for row in candles_data:\n        if isinstance(row, dict) and row.get(\"close\") is not None:\n            candles.append(row)\ncandles = candles[-lookback:]\n\nif not candles:\n    result = {\"error\": \"no_candles\", \"candles_used\": 0}\nelse:\n    current_price = None\n    try: current_price = float(candles[-1][\"close\"])\n    except (TypeError, ValueError, KeyError): pass\n\n    if current_price is None:\n        result = {\"error\": \"no_price\", \"candles_used\": len(candles)}\n    else:\n        lows_set  = set()\n        highs_set = set()\n        for c in candles:\n            if c.get(\"low\")  is not None:\n                try: lows_set.add(float(c[\"low\"]))\n                except (TypeError, ValueError): pass\n            if c.get(\"high\") is not None:\n                try: highs_set.add(float(c[\"high\"]))\n                except (TypeError, ValueError): pass\n\n        lows_below = []\n        for _l in lows_set:\n            if _l <= current_price:\n                lows_below.append(_l)\n        lows_below.sort()\n        highs_above = []\n        for _h in highs_set:\n            if _h >= current_price:\n                highs_above.append(_h)\n        highs_above.sort()\n        support    = lows_below[-1]  if lows_below  else None\n        resistance = highs_above[0] if highs_above else None\n\n        result = {\n            \"nearest_resistance\": round(resistance, 6) if resistance is not None else None,\n            \"nearest_support\":    round(support, 6)    if support    is not None else None,\n            \"current_price\":      round(current_price, 6),\n            \"candles_used\":       len(candles),\n        }\n\n        atr_val = None\n        if isinstance(atr_data, dict) and atr_data.get(\"latest\") is not None:\n            try: atr_val = float(atr_data[\"latest\"])\n            except (TypeError, ValueError): pass\n\n        if atr_val and atr_val > 0 and resistance is not None and support is not None:\n            dist_res = resistance - current_price\n            dist_sup = current_price - support\n            result[\"sr_gate_passed_long\"]        = (dist_res / atr_val) >= sr_threshold\n            result[\"sr_gate_passed_short\"]       = (dist_sup / atr_val) >= sr_threshold\n            result[\"distance_to_resistance_atr\"] = round(dist_res / atr_val, 3)\n            result[\"distance_to_support_atr\"]    = round(dist_sup / atr_val, 3)\n"
    },
    {
      "id": "snip_calc_structural_sr",
      "name": "Structural S/R",
      "version": "1",
      "tags": "SnapshotCalc",
      "description": "Higher-timeframe structural support and resistance with ATR-based minimum gap filter. Outputs: structural_resistance, structural_support, atr, min_gap, candles_used.",
      "code": "# === KONFIGURATION ===\n# Beispiel: candles_key = \"h1_recent\"  — mindestens 'lookback' Kerzen konfigurieren\ncandles_key = \"h1_recent\"   # get_candles Block (mindestens lookback Kerzen nötig)\natr_key     = \"atr_primary\" # calculate_indicator Block ATR\nlookback    = 72            # Anzahl Kerzen für Strukturerkennung (Standard: 72, min: 72)\nmin_gap_atr = 0.15          # Mindestabstand Level ↔ Kurs in ATR-Einheiten (Standard: 0.15)\n                            # Beispiel: min_gap_atr = 0.30 → weitmaschigere Filterung\n\n# === LOGIK (nur bei Bedarf anpassen) ===\ncandles_data = tool_outputs.get(candles_key) or []\natr_data     = tool_outputs.get(atr_key) or {}\n\ncandles = []\nif isinstance(candles_data, list):\n    for row in candles_data:\n        if isinstance(row, dict) and row.get(\"close\") is not None:\n            candles.append(row)\ncandles = candles[-lookback:]\n\nif not candles:\n    result = {\"error\": \"no_candles\", \"candles_used\": 0}\nelse:\n    current_price = None\n    try: current_price = float(candles[-1][\"close\"])\n    except (TypeError, ValueError, KeyError): pass\n\n    if current_price is None:\n        result = {\"error\": \"no_price\", \"candles_used\": len(candles)}\n    else:\n        atr_val = None\n        if isinstance(atr_data, dict) and atr_data.get(\"latest\") is not None:\n            try: atr_val = float(atr_data[\"latest\"])\n            except (TypeError, ValueError): pass\n\n        min_gap = (atr_val * min_gap_atr) if atr_val else 0.0\n\n        lows_set  = set()\n        highs_set = set()\n        for c in candles:\n            if c.get(\"low\") is not None:\n                try: lows_set.add(float(c[\"low\"]))\n                except (TypeError, ValueError): pass\n            if c.get(\"high\") is not None:\n                try: highs_set.add(float(c[\"high\"]))\n                except (TypeError, ValueError): pass\n\n        lows_below = []\n        for _l in lows_set:\n            if _l <= current_price - min_gap:\n                lows_below.append(_l)\n        lows_below.sort()\n        highs_above = []\n        for _h in highs_set:\n            if _h >= current_price + min_gap:\n                highs_above.append(_h)\n        highs_above.sort()\n        support    = lows_below[-1]  if lows_below  else None\n        resistance = highs_above[0] if highs_above else None\n\n        result = {\n            \"structural_resistance\": round(resistance, 6) if resistance is not None else None,\n            \"structural_support\":    round(support, 6)    if support    is not None else None,\n            \"current_price\":         round(current_price, 6),\n            \"atr\":                   round(atr_val, 6) if atr_val is not None else None,\n            \"min_gap\":               round(min_gap, 6),\n            \"candles_used\":          len(candles),\n        }\n"
    },
    {
      "id": "snip_calc_close_quality",
      "name": "Close Quality",
      "version": "1",
      "tags": "SnapshotCalc",
      "description": "Classifies the last N candle closes by ATR-relative body size. Outputs: summary (bullish_conviction/bearish_conviction/mild_*/indecisive/mixed), strong_bullish, strong_bearish, per-candle direction+strength.",
      "code": "# === KONFIGURATION ===\n# Beispiel: candles_key = \"m5_recent\"  — mindestens recent_count Kerzen konfigurieren\ncandles_key          = \"m5_recent\"   # get_candles Block\natr_key              = \"atr_primary\" # calculate_indicator Block ATR\nrecent_count         = 3             # Anzahl der letzten Kerzen (Standard: 3)\nweak_threshold_atr   = 0.20          # Untergrenze für \"moderate\" Körpergrösse in ATR (Standard: 0.20)\nstrong_threshold_atr = 0.60          # Untergrenze für \"strong\" Körpergrösse in ATR (Standard: 0.60)\n                                     # Beispiel: strong_threshold_atr = 0.80 → nur sehr starke Kerzen zählen\n\n# === LOGIK (nur bei Bedarf anpassen) ===\ncandles_data = tool_outputs.get(candles_key) or []\natr_data     = tool_outputs.get(atr_key) or {}\n\natr_val = None\nif isinstance(atr_data, dict) and atr_data.get(\"latest\") is not None:\n    try: atr_val = float(atr_data[\"latest\"])\n    except (TypeError, ValueError): pass\n\nrecent = []\nif isinstance(candles_data, list):\n    recent = [c for c in candles_data if isinstance(c, dict)][-recent_count:]\n\nif not recent:\n    result = {\"candles_used\": 0, \"summary\": \"no_data\", \"candles\": []}\nelse:\n    per_candle = []\n    strong_bull = strong_bear = 0\n    for row in recent:\n        o = c_val = None\n        try: o     = float(row[\"open\"])\n        except (TypeError, ValueError, KeyError): pass\n        try: c_val = float(row[\"close\"])\n        except (TypeError, ValueError, KeyError): pass\n        if o is None or c_val is None:\n            continue\n        body      = abs(c_val - o)\n        direction = \"bullish\" if c_val >= o else \"bearish\"\n        if atr_val and atr_val > 0:\n            ratio    = body / atr_val\n            strength = \"strong\" if ratio >= strong_threshold_atr else \"moderate\" if ratio >= weak_threshold_atr else \"weak\"\n        else:\n            strength = \"unknown\"\n        if strength == \"strong\":\n            if direction == \"bullish\": strong_bull += 1\n            else:                      strong_bear += 1\n        per_candle.append({\"direction\": direction, \"strength\": strength})\n\n    if   strong_bull > strong_bear: summary = \"bullish_conviction\" if strong_bull >= 2 else \"mild_bullish\"\n    elif strong_bear > strong_bull: summary = \"bearish_conviction\" if strong_bear >= 2 else \"mild_bearish\"\n    elif strong_bull == 0 and strong_bear == 0: summary = \"indecisive\"\n    else: summary = \"mixed\"\n\n    result = {\n        \"summary\":        summary,\n        \"strong_bullish\": strong_bull,\n        \"strong_bearish\": strong_bear,\n        \"candles\":        per_candle,\n        \"candles_used\":   len(per_candle),\n    }\n"
    },
    {
      "id": "snip_calc_entry_gates",
      "name": "Entry Gates",
      "version": "1",
      "tags": "SnapshotCalc",
      "description": "Aggregates micro_sr gate flags, RSI conflict, and trend state into a long/short readiness summary. Reads prior calculation block results via their block IDs. Outputs: long{sr_gate_passed, rsi_blocked, trend_aligned}, short{...}.",
      "code": "# === KONFIGURATION ===\n# Block-IDs der vorherigen Calculation Blocks (nicht Tool-Block output_keys!)\n# Beispiel: micro_sr_key = \"micro_sr_1\"  wenn der Micro S/R Calc-Block so heisst\nmicro_sr_key     = \"micro_sr_1\"  # Calc-Block der sr_gate_passed_long/short liefert\nrsi_key          = \"rsi_primary\" # Tool-Block RSI (liefert conflict-Dict nach Transformation)\ntrend_key        = \"trend_1\"     # Calc-Block der trend_state liefert\nm5_structure_key = \"\"            # Calc-Block der structure liefert — leer = nicht prüfen\n\n# Erlaubte M5-Strukturen für Long/Short-Bestätigung\n# Beispiel: long_confirmed = [\"constructive_recovery\", \"constructive_pullback\"]\nlong_confirmed  = [\"constructive_recovery\", \"constructive_pullback\"]\nshort_confirmed = [\"bearish_pressure\", \"soft_rejection\"]\n\n# === LOGIK (nur bei Bedarf anpassen) ===\n# Hinweis: tool_outputs enthält hier SOWOHL Tool-Block-Outputs ALS AUCH\n#          Ergebnisse vorheriger Calculation Blocks (über ihre Block-ID)\nmicro_sr   = tool_outputs.get(micro_sr_key) if isinstance(tool_outputs.get(micro_sr_key), dict) else {}\nrsi_data   = tool_outputs.get(rsi_key)      if isinstance(tool_outputs.get(rsi_key), dict)      else {}\ntrend_data = tool_outputs.get(trend_key)    if isinstance(tool_outputs.get(trend_key), dict)    else {}\n\nm5_structure = \"\"\nif m5_structure_key:\n    m5_raw = tool_outputs.get(m5_structure_key)\n    if isinstance(m5_raw, dict): m5_structure = str(m5_raw.get(\"structure\") or \"\")\n    elif m5_raw:                 m5_structure = str(m5_raw)\n\nsr_gate_long  = bool(micro_sr.get(\"sr_gate_passed_long\",  False))\nsr_gate_short = bool(micro_sr.get(\"sr_gate_passed_short\", False))\nrsi_conflict  = rsi_data.get(\"conflict\") if isinstance(rsi_data.get(\"conflict\"), dict) else {}\ntrend_state   = str(trend_data.get(\"trend_state\") or \"\")\n\nresult = {\n    \"long\": {\n        \"sr_gate_passed\": sr_gate_long,\n        \"rsi_blocked\":    rsi_conflict.get(\"long\")  == \"hard_conflict\",\n        \"m5_confirmed\":   m5_structure in set(long_confirmed)  if m5_structure else False,\n        \"trend_aligned\":  trend_state in {\"confirmed_bullish\", \"early_bullish_recovery\"},\n    },\n    \"short\": {\n        \"sr_gate_passed\": sr_gate_short,\n        \"rsi_blocked\":    rsi_conflict.get(\"short\") == \"hard_conflict\",\n        \"m5_confirmed\":   m5_structure in set(short_confirmed) if m5_structure else False,\n        \"trend_aligned\":  trend_state in {\"confirmed_bearish\", \"early_bearish_breakdown\"},\n    },\n}\n"
    },
    {
      "id": "snip_calc_m5_structure",
      "name": "M5 Structure",
      "version": "1",
      "tags": "SnapshotCalc",
      "description": "Classifies the M5 candle structure into: constructive_recovery, constructive_pullback, bearish_pressure, soft_rejection, range_bound, indeterminate, insufficient_data. Also outputs range_bound flag and range statistics.",
      "code": "# === KONFIGURATION ===\n# Beispiel: candles_key = \"m5_recent\"  — mindestens 'lookback' Kerzen konfigurieren\ncandles_key = \"m5_recent\"   # get_candles Block M5\natr_key     = \"atr_primary\" # calculate_indicator Block ATR\nlookback    = 12            # Anzahl Kerzen für Strukturerkennung (Standard: 12)\n\n# === LOGIK (nur bei Bedarf anpassen) ===\ncandles_data = tool_outputs.get(candles_key) or []\natr_data     = tool_outputs.get(atr_key) or {}\n\natr_val = None\nif isinstance(atr_data, dict) and atr_data.get(\"latest\") is not None:\n    try: atr_val = float(atr_data[\"latest\"])\n    except (TypeError, ValueError): pass\n\ncandles = []\nif isinstance(candles_data, list):\n    for row in candles_data:\n        if isinstance(row, dict) and row.get(\"close\") is not None:\n            candles.append(row)\ncandles = candles[-lookback:]\n\nif len(candles) < 4:\n    result = {\"structure\": \"insufficient_data\", \"range_bound\": False, \"range_size\": None, \"largest_candle\": None}\nelse:\n    all_highs = [float(c[\"high\"]) for c in candles if c.get(\"high\") is not None]\n    all_lows  = [float(c[\"low\"])  for c in candles if c.get(\"low\")  is not None]\n    range_size = (max(all_highs) - min(all_lows)) if all_highs and all_lows else None\n    body_sizes = []\n    for c in candles:\n        if c.get(\"open\") is not None and c.get(\"close\") is not None:\n            try: body_sizes.append(abs(float(c[\"close\"]) - float(c[\"open\"])))\n            except (TypeError, ValueError): pass\n    largest_candle = max(body_sizes) if body_sizes else None\n\n    range_bound = bool(\n        atr_val and range_size is not None and largest_candle is not None\n        and range_size <= (1.2 * atr_val) and largest_candle <= (0.4 * atr_val)\n    )\n\n    # Classify from last 4 closes\n    last4 = candles[-4:]\n    closes = []\n    for c in last4:\n        if c.get(\"close\") is not None:\n            try: closes.append(float(c[\"close\"]))\n            except (TypeError, ValueError): pass\n\n    if len(closes) < 4:\n        structure = \"insufficient_data\"\n    elif range_bound:\n        structure = \"range_bound\"\n    else:\n        c0, c1, c2, c3 = closes\n        if c3 > c2 > c1 and c3 > c0:\n            structure = \"constructive_recovery\"\n        elif c3 < c2 < c1 and c3 < c0:\n            structure = \"bearish_pressure\"\n        elif c0 > c1 and c2 > c1 and c3 > c1:\n            structure = \"constructive_pullback\"\n        elif c0 < c1 and c2 < c1 and c3 < c1:\n            structure = \"soft_rejection\"\n        else:\n            structure = \"indeterminate\"\n\n    result = {\n        \"structure\":      structure,\n        \"range_bound\":    range_bound,\n        \"range_size\":     round(range_size, 6)     if range_size     is not None else None,\n        \"largest_candle\": round(largest_candle, 6) if largest_candle is not None else None,\n    }\n"
    },
    {
      "id": "snip_calc_swing_sr_gate",
      "name": "Swing S/R Gate",
      "version": "1",
      "tags": "SnapshotCalc",
      "description": "Gate computed from get_swing_levels tool output. Reads nearest_resistance/support and ATR directly from the swing tool result. Outputs: nearest_resistance, nearest_support, sr_gate_passed_long/short, distance_to_*_atr, atr, candles_used.",
      "code": "# === KONFIGURATION ===\n# Beispiel: swing_key = \"swing_levels\"  wenn der get_swing_levels Tool-Block so heisst\nswing_key    = \"swing_levels\" # get_swing_levels Tool-Block output_key\nsr_threshold = 0.50           # Mindestabstand in ATR-Einheiten für Gate-Pass (Standard: 0.50)\n\n# === LOGIK (nur bei Bedarf anpassen) ===\nswing = tool_outputs.get(swing_key)\nswing = swing if isinstance(swing, dict) else {}\n\nnearest_res   = swing.get(\"nearest_resistance\")\nnearest_sup   = swing.get(\"nearest_support\")\natr_value     = swing.get(\"atr\")\ncurrent_price = swing.get(\"current_price\")\n\nres_price = nearest_res.get(\"price\") if isinstance(nearest_res, dict) else None\nsup_price = nearest_sup.get(\"price\") if isinstance(nearest_sup, dict) else None\n\natr_val = None\nif atr_value is not None:\n    try: atr_val = float(atr_value)\n    except (TypeError, ValueError): pass\n\nresult = {\n    \"nearest_resistance\": round(float(res_price), 6) if res_price is not None else None,\n    \"nearest_support\":    round(float(sup_price), 6) if sup_price is not None else None,\n    \"current_price\":      round(float(current_price), 6) if current_price is not None else None,\n    \"candles_used\":       swing.get(\"candles_available\"),\n    \"atr\":                round(atr_val, 6) if atr_val is not None else None,\n}\n\nif atr_val and atr_val > 0 and isinstance(nearest_res, dict) and isinstance(nearest_sup, dict):\n    dist_res = nearest_res.get(\"distance\")\n    dist_sup = nearest_sup.get(\"distance\")\n    if dist_res is not None:\n        try:\n            dist_res = float(dist_res)\n            result[\"sr_gate_passed_long\"]        = (dist_res / atr_val) >= sr_threshold\n            result[\"distance_to_resistance_atr\"] = round(dist_res / atr_val, 3)\n        except (TypeError, ValueError):\n            result[\"sr_gate_passed_long\"] = False\n    else:\n        result[\"sr_gate_passed_long\"] = False\n    if dist_sup is not None:\n        try:\n            dist_sup = float(dist_sup)\n            result[\"sr_gate_passed_short\"]      = (dist_sup / atr_val) >= sr_threshold\n            result[\"distance_to_support_atr\"]   = round(dist_sup / atr_val, 3)\n        except (TypeError, ValueError):\n            result[\"sr_gate_passed_short\"] = False\n    else:\n        result[\"sr_gate_passed_short\"] = False\nelse:\n    result[\"sr_gate_passed_long\"]  = False\n    result[\"sr_gate_passed_short\"] = False\n"
    },
    {
      "id": "snip_calc_recent_context",
      "name": "Recent Context",
      "version": "1",
      "tags": "SnapshotCalc",
      "description": "Extracts the last N candles from short- and long-timeframe candle blocks for LLM context. Outputs: short_last_N and long_last_N lists with OHLCV dicts.",
      "code": "# === KONFIGURATION ===\n# Beispiel: candles_short_key = \"m5_recent\"  wenn der kurze TF Block so heisst\ncandles_short_key = \"m5_recent\"   # get_candles Block kurzer Timeframe\ncandles_long_key  = \"h1_recent\"   # get_candles Block langer Timeframe\nshort_last        = 6             # Letzte N Kerzen vom kurzen TF (Standard: 6)\nlong_last         = 4             # Letzte N Kerzen vom langen TF  (Standard: 4)\n\n# === LOGIK (nur bei Bedarf anpassen) ===\ncandles_short = tool_outputs.get(candles_short_key) or []\ncandles_long  = tool_outputs.get(candles_long_key)  or []\n\ndef _compact(c):\n    return {\n        \"time\":  c.get(\"timestamp\") or c.get(\"time\"),\n        \"open\":  c.get(\"open\"),\n        \"high\":  c.get(\"high\"),\n        \"low\":   c.get(\"low\"),\n        \"close\": c.get(\"close\"),\n    }\n\nresult = {}\nif isinstance(candles_short, list) and candles_short:\n    short_out = []\n    for c in candles_short[-short_last:]:\n        if isinstance(c, dict):\n            short_out.append(_compact(c))\n    result[f\"short_last_{short_last}\"] = short_out\nif isinstance(candles_long, list) and candles_long:\n    long_out = []\n    for c in candles_long[-long_last:]:\n        if isinstance(c, dict):\n            long_out.append(_compact(c))\n    result[f\"long_last_{long_last}\"] = long_out\n"
    },
    {
      "id": "mq8jdjvlj8jw4t6j2gj",
      "name": "Trend Analysis",
      "version": "2",
      "tags": "SnapshotCalc",
      "description": "EMA-based trend direction and state. Reads ema_fast, ema_slow and current candles from tool_outputs. Outputs: direction, h1_trend, trend_state, ema values, slopes, price position.",
      "code": "# === KONFIGURATION = TREND V2 ===\ncandles_key  = \"h1_recent\"\nema_fast_key = \"ema_fast\"\nema_slow_key = \"ema_slow\"\nm5_key       = \"m5_recent\"\nrsi_key      = \"rsi_primary\"\n\nema_fast_data = tool_outputs.get(ema_fast_key) or {}\nema_slow_data = tool_outputs.get(ema_slow_key) or {}\ncandles_data  = tool_outputs.get(candles_key) or []\nm5_data       = tool_outputs.get(m5_key) or []\nrsi_data      = tool_outputs.get(rsi_key) or {}\n\ndef _float_or_none(x):\n    try:\n        return float(x)\n    except (TypeError, ValueError):\n        return None\n\nema_fast_val = _float_or_none(ema_fast_data.get(\"latest\")) if isinstance(ema_fast_data, dict) else None\nema_slow_val = _float_or_none(ema_slow_data.get(\"latest\")) if isinstance(ema_slow_data, dict) else None\n\nema_fast_dir = str(ema_fast_data.get(\"direction\") or \"flat\") if isinstance(ema_fast_data, dict) else \"flat\"\nema_slow_dir = str(ema_slow_data.get(\"direction\") or \"flat\") if isinstance(ema_slow_data, dict) else \"flat\"\n\ncurrent_price = None\nif isinstance(candles_data, list) and candles_data:\n    current_price = _float_or_none(candles_data[-1].get(\"close\"))\n\ndef _pvl(price, level):\n    if price is None or level is None:\n        return \"unknown\"\n    if price > level + 1e-9:\n        return \"above\"\n    if price < level - 1e-9:\n        return \"below\"\n    return \"at\"\n\npf = _pvl(current_price, ema_fast_val)\nps = _pvl(current_price, ema_slow_val)\n\n# 1. EMA-Kontext, aber noch keine Trade-Richtung\nema_context = \"neutral\"\nif ema_fast_val is not None and ema_slow_val is not None:\n    if ema_fast_val > ema_slow_val:\n        ema_context = \"bullish\"\n    elif ema_fast_val < ema_slow_val:\n        ema_context = \"bearish\"\n\n# 2. EMA-Alignment / Bestätigung\nema_alignment = \"mixed\"\n\nif ema_context == \"bullish\":\n    if pf == \"above\" and ps == \"above\" and ema_fast_dir == \"rising\" and ema_slow_dir == \"rising\":\n        ema_alignment = \"confirmed_bullish\"\n    else:\n        ema_alignment = \"weak_or_early_bullish\"\n\nelif ema_context == \"bearish\":\n    if pf == \"below\" and ps == \"below\" and ema_fast_dir == \"falling\" and ema_slow_dir == \"falling\":\n        ema_alignment = \"confirmed_bearish\"\n    else:\n        ema_alignment = \"weak_or_early_bearish\"\n\n# 3. M5 Micro-Flow\nm5_flow = \"unknown\"\nm5_higher_closes = False\nm5_higher_lows = False\nm5_closes_used = []\nm5_lows_used = []\n\nif isinstance(m5_data, list) and len(m5_data) >= 4:\n    recent_m5 = m5_data[-4:]\n\n    closes = []\n    lows = []\n\n    for c in recent_m5:\n        if isinstance(c, dict):\n            close_val = _float_or_none(c.get(\"close\"))\n            low_val = _float_or_none(c.get(\"low\"))\n\n            closes.append(close_val)\n            lows.append(low_val)\n\n    all_closes_valid = True\n    for v in closes:\n        if v is None:\n            all_closes_valid = False\n            break\n\n    if len(closes) >= 4 and all_closes_valid:\n        up_count = 0\n        down_count = 0\n\n        for i in range(1, len(closes)):\n            if closes[i] > closes[i - 1]:\n                up_count += 1\n            elif closes[i] < closes[i - 1]:\n                down_count += 1\n\n        if up_count >= 3:\n            m5_flow = \"bullish_recovery\"\n            m5_higher_closes = True\n        elif down_count >= 3:\n            m5_flow = \"bearish_continuation\"\n        elif up_count > down_count:\n            m5_flow = \"bullish_leaning\"\n        elif down_count > up_count:\n            m5_flow = \"bearish_leaning\"\n        else:\n            m5_flow = \"mixed\"\n\n    all_lows_valid = True\n    for v in lows:\n        if v is None:\n            all_lows_valid = False\n            break\n\n    if len(lows) >= 4 and all_lows_valid:\n        higher_low_count = 0\n\n        for i in range(1, len(lows)):\n            if lows[i] >= lows[i - 1]:\n                higher_low_count += 1\n\n        if higher_low_count >= 2:\n            m5_higher_lows = True\n\n    for v in closes:\n        if v is not None:\n            m5_closes_used.append(round(v, 6))\n\n    for v in lows:\n        if v is not None:\n            m5_lows_used.append(round(v, 6))\n\n# 4. RSI-Recovery\nrsi_recovery = False\nrsi_latest = None\n\nif isinstance(rsi_data, dict):\n    vals = rsi_data.get(\"values\") or []\n    try:\n        rsi_vals = [float(v[\"value\"]) for v in vals[-3:]]\n        if rsi_vals:\n            rsi_latest = rsi_vals[-1]\n        if len(rsi_vals) == 3:\n            rsi_recovery = rsi_vals[-1] > rsi_vals[-2] > rsi_vals[-3]\n    except (TypeError, ValueError, KeyError):\n        pass\n\n# 5. Continuation Direction nur bei sauberer Bestätigung\ncontinuation_direction = \"none\"\n\nif ema_alignment == \"confirmed_bullish\" and m5_flow != \"bearish_continuation\":\n    continuation_direction = \"long\"\nelif ema_alignment == \"confirmed_bearish\" and m5_flow != \"bullish_recovery\":\n    continuation_direction = \"short\"\n\n# 6. Reversal Candidate\nreversal_candidate = \"none\"\ndirection = continuation_direction if continuation_direction != \"none\" else \"neutral\"\n\nif ema_context == \"bearish\" and m5_flow == \"bullish_recovery\" and rsi_recovery:\n    reversal_candidate = \"long\"\n    direction = \"long_watch\"\n\nelif ema_context == \"bullish\" and m5_flow == \"bearish_continuation\" and not rsi_recovery:\n    reversal_candidate = \"short\"\n    direction = \"short_watch\"\n\n# 7. Finaler Trend-State\nif direction == \"long_watch\":\n    trend_state = \"bearish_context_but_bullish_recovery\"\nelif direction == \"short_watch\":\n    trend_state = \"bullish_context_but_bearish_pullback\"\nelif ema_alignment == \"confirmed_bullish\":\n    trend_state = \"confirmed_bullish\"\nelif ema_alignment == \"confirmed_bearish\":\n    trend_state = \"confirmed_bearish\"\nelse:\n    trend_state = \"mixed_or_early\"\n\nresult = {\n    \"direction\": direction,\n    \"ema_context\": ema_context,\n    \"ema_alignment\": ema_alignment,\n    \"continuation_direction\": continuation_direction,\n    \"reversal_candidate\": reversal_candidate,\n    \"entry_timeframe_flow\": m5_flow,\n    \"m5_higher_closes\": m5_higher_closes,\n    \"m5_higher_lows\": m5_higher_lows,\n    \"rsi_latest\": round(rsi_latest, 3) if rsi_latest is not None else None,\n    \"rsi_recovery\": rsi_recovery,\n    \"ema_fast\": round(ema_fast_val, 6) if ema_fast_val is not None else None,\n    \"ema_fast_slope\": ema_fast_dir,\n    \"ema_slow\": round(ema_slow_val, 6) if ema_slow_val is not None else None,\n    \"ema_slow_slope\": ema_slow_dir,\n    \"price_vs_ema_fast\": pf,\n    \"price_vs_ema_slow\": ps,\n    \"trend_state\": trend_state,\n}\n\nif current_price is not None:\n    result[\"current_price\"] = round(current_price, 6)"
    },
    {
      "id": "mq8l0pqqqkfnc0i7h7p",
      "name": "Entry Gates",
      "version": "2",
      "tags": "SnapshotCalc",
      "description": "Aggregates micro_sr gate flags, RSI conflict, and trend state into a long/short readiness summary. Reads prior calculation block results via their block IDs. Outputs: long{sr_gate_passed, rsi_blocked, trend_aligned}, short{...}.",
      "code": "# === KONFIGURATION ===\n# Block-IDs der vorherigen Calculation Blocks (nicht Tool-Block output_keys!)\n# Beispiel: micro_sr_key = \"micro_sr_1\"  wenn der Micro S/R Calc-Block so heisst\nmicro_sr_key     = \"micro_sr\"    # Calc-Block der sr_gate_passed_long/short liefert\nrsi_key          = \"rsi_primary\" # Tool-Block RSI (liefert conflict-Dict nach Transformation)\ntrend_key        = \"trend\"       # Calc-Block der trend_state liefert\nm5_structure_key = \"\"            # Calc-Block der structure liefert — leer = nicht prüfen\n\nstrategy_aggressiveness = \"CONSERVATIVE\"\n\n# === DATEN LADEN ===\nmicro_sr   = tool_outputs.get(micro_sr_key) or {}\nrsi_data   = tool_outputs.get(rsi_key) or {}\ntrend_data = tool_outputs.get(trend_key) or {}\n\n# === MICRO S/R ===\nsr_gate_long = bool(micro_sr.get(\"sr_gate_passed_long\", False))\nsr_gate_short = bool(micro_sr.get(\"sr_gate_passed_short\", False))\n\ndistance_to_support_atr = None\ndistance_to_resistance_atr = None\n\ntry:\n    distance_to_support_atr = float(micro_sr.get(\"distance_to_support_atr\"))\nexcept:\n    pass\n\ntry:\n    distance_to_resistance_atr = float(micro_sr.get(\"distance_to_resistance_atr\"))\nexcept:\n    pass\n\nnear_support = False\nnear_resistance = False\n\nif distance_to_support_atr is not None:\n    if distance_to_support_atr < 0.30:\n        near_support = True\n\nif distance_to_resistance_atr is not None:\n    if distance_to_resistance_atr < 0.30:\n        near_resistance = True\n\n# === RSI ===\nrsi_conflict = rsi_data.get(\"conflict\")\nif not isinstance(rsi_conflict, dict):\n    rsi_conflict = {}\n\nrsi_level = str(rsi_data.get(\"level\") or \"\")\nrsi_direction = str(rsi_data.get(\"direction\") or \"\")\n\nrsi_value = None\ntry:\n    rsi_value = float(rsi_data.get(\"value\"))\nexcept:\n    pass\n\nlong_rsi_conflict = str(rsi_conflict.get(\"long\") or \"\")\nshort_rsi_conflict = str(rsi_conflict.get(\"short\") or \"\")\n\nlong_rsi_blocked = False\nshort_rsi_blocked = False\nlong_rsi_warning = \"\"\nshort_rsi_warning = \"\"\n\nif long_rsi_conflict == \"hard_conflict\":\n    long_rsi_blocked = True\n    long_rsi_warning = \"hard_conflict\"\n\nif short_rsi_conflict == \"hard_conflict\":\n    short_rsi_blocked = True\n    short_rsi_warning = \"hard_conflict\"\n\nif strategy_aggressiveness == \"CONSERVATIVE\":\n    if long_rsi_conflict == \"late_entry_risk\":\n        long_rsi_blocked = True\n        long_rsi_warning = \"late_entry_risk\"\n\n    if short_rsi_conflict == \"late_entry_risk\":\n        short_rsi_blocked = True\n        short_rsi_warning = \"late_entry_risk\"\n\n    if rsi_level == \"extreme_oversold\":\n        short_rsi_blocked = True\n        if short_rsi_warning == \"\":\n            short_rsi_warning = \"extreme_oversold_late_short_risk\"\n\n    if rsi_level == \"extreme_overbought\":\n        long_rsi_blocked = True\n        if long_rsi_warning == \"\":\n            long_rsi_warning = \"extreme_overbought_late_long_risk\"\n\n# === TREND / FLOW ===\ntrend_state = str(trend_data.get(\"trend_state\") or \"\")\ndirection = str(trend_data.get(\"direction\") or \"\")\nema_context = str(trend_data.get(\"ema_context\") or \"\")\nema_alignment = str(trend_data.get(\"ema_alignment\") or \"\")\nentry_timeframe_flow = str(trend_data.get(\"entry_timeframe_flow\") or \"\")\nreversal_candidate = str(trend_data.get(\"reversal_candidate\") or \"\")\ncontinuation_direction = str(trend_data.get(\"continuation_direction\") or \"\")\n\nentry_flow_for_gate = entry_timeframe_flow\n\nif m5_structure_key:\n    m5_raw = tool_outputs.get(m5_structure_key)\n    if isinstance(m5_raw, dict):\n        entry_flow_for_gate = str(m5_raw.get(\"structure\") or \"\")\n    elif m5_raw:\n        entry_flow_for_gate = str(m5_raw)\n\n# === M5 CONFIRMATION ===\nm5_confirmed_long = False\nm5_confirmed_short = False\n\nif entry_flow_for_gate == \"constructive_recovery\":\n    m5_confirmed_long = True\nif entry_flow_for_gate == \"constructive_pullback\":\n    m5_confirmed_long = True\nif entry_flow_for_gate == \"bullish_recovery\":\n    m5_confirmed_long = True\nif entry_flow_for_gate == \"bullish_leaning\":\n    m5_confirmed_long = True\n\nif entry_flow_for_gate == \"bearish_pressure\":\n    m5_confirmed_short = True\nif entry_flow_for_gate == \"soft_rejection\":\n    m5_confirmed_short = True\nif entry_flow_for_gate == \"bearish_continuation\":\n    m5_confirmed_short = True\nif entry_flow_for_gate == \"bearish_leaning\":\n    m5_confirmed_short = True\n\n# === TREND ALIGNMENT ===\ntrend_aligned_long = False\ntrend_aligned_short = False\n\nif trend_state == \"confirmed_bullish\":\n    trend_aligned_long = True\nif trend_state == \"early_bullish_recovery\":\n    trend_aligned_long = True\nif direction == \"long\":\n    trend_aligned_long = True\n\nif trend_state == \"confirmed_bearish\":\n    trend_aligned_short = True\nif trend_state == \"early_bearish_breakdown\":\n    trend_aligned_short = True\nif direction == \"short\":\n    trend_aligned_short = True\n\n# Reversal / Watch überschreibt Trendrichtung\nif direction == \"long_watch\":\n    trend_aligned_long = True\n    trend_aligned_short = False\n\nif direction == \"short_watch\":\n    trend_aligned_short = True\n    trend_aligned_long = False\n\nif reversal_candidate == \"long\":\n    trend_aligned_long = True\n    trend_aligned_short = False\n\nif reversal_candidate == \"long_support_reversal\":\n    trend_aligned_long = True\n    trend_aligned_short = False\n\nif reversal_candidate == \"short\":\n    trend_aligned_short = True\n    trend_aligned_long = False\n\nif reversal_candidate == \"short_resistance_reversal\":\n    trend_aligned_short = True\n    trend_aligned_long = False\n\n# === LOCATION BLOCKS ===\nlong_location_blocked = False\nshort_location_blocked = False\nlong_location_warning = \"\"\nshort_location_warning = \"\"\n\nif near_resistance and not sr_gate_long:\n    long_location_blocked = True\n    long_location_warning = \"too_close_to_resistance\"\n\nif near_support and not sr_gate_short:\n    short_location_blocked = True\n    short_location_warning = \"too_close_to_support\"\n\n# === REVERSAL WATCH ===\nlong_reversal_watch = False\nshort_reversal_watch = False\n\nif ema_context == \"bearish\":\n    if near_support:\n        if entry_flow_for_gate == \"bullish_recovery\" or entry_flow_for_gate == \"bullish_leaning\":\n            long_reversal_watch = True\n\nif ema_context == \"bullish\":\n    if near_resistance:\n        if entry_flow_for_gate == \"bearish_continuation\" or entry_flow_for_gate == \"bearish_leaning\":\n            short_reversal_watch = True\n\nif long_reversal_watch:\n    trend_aligned_long = True\n    trend_aligned_short = False\n\nif short_reversal_watch:\n    trend_aligned_short = True\n    trend_aligned_long = False\n\n# === ENTRY ALLOWED ===\nlong_entry_allowed = False\nshort_entry_allowed = False\n\nif sr_gate_long and not long_rsi_blocked and m5_confirmed_long and trend_aligned_long and not long_location_blocked:\n    long_entry_allowed = True\n\nif sr_gate_short and not short_rsi_blocked and m5_confirmed_short and trend_aligned_short and not short_location_blocked:\n    short_entry_allowed = True\n\n# === ENTRY QUALITY ===\nlong_entry_quality = \"POOR\"\nshort_entry_quality = \"POOR\"\n\nif long_entry_allowed:\n    long_entry_quality = \"GOOD\"\nelse:\n    if trend_aligned_long and m5_confirmed_long and not long_rsi_blocked and not long_location_blocked:\n        long_entry_quality = \"WATCH\"\n\nif short_entry_allowed:\n    short_entry_quality = \"GOOD\"\nelse:\n    if trend_aligned_short and m5_confirmed_short and not short_rsi_blocked and not short_location_blocked:\n        short_entry_quality = \"WATCH\"\n\n# === BLOCK REASONS ===\nlong_block_reasons = []\nshort_block_reasons = []\n\nif not sr_gate_long:\n    long_block_reasons.append(\"sr_gate_not_passed\")\nif long_rsi_blocked:\n    if long_rsi_warning:\n        long_block_reasons.append(\"rsi_blocked_\" + long_rsi_warning)\n    else:\n        long_block_reasons.append(\"rsi_blocked\")\nif not m5_confirmed_long:\n    long_block_reasons.append(\"m5_not_confirmed\")\nif not trend_aligned_long:\n    long_block_reasons.append(\"trend_not_aligned\")\nif long_location_blocked:\n    long_block_reasons.append(long_location_warning)\n\nif not sr_gate_short:\n    short_block_reasons.append(\"sr_gate_not_passed\")\nif short_rsi_blocked:\n    if short_rsi_warning:\n        short_block_reasons.append(\"rsi_blocked_\" + short_rsi_warning)\n    else:\n        short_block_reasons.append(\"rsi_blocked\")\nif not m5_confirmed_short:\n    short_block_reasons.append(\"m5_not_confirmed\")\nif not trend_aligned_short:\n    short_block_reasons.append(\"trend_not_aligned\")\nif short_location_blocked:\n    short_block_reasons.append(short_location_warning)\n\n# === BIAS / BEST ACTION ===\nbias = \"NEUTRAL\"\nbest_action = \"WAIT\"\nprimary_block_reason = \"\"\n\nif long_entry_allowed and not short_entry_allowed:\n    bias = \"LONG\"\n    best_action = \"LONG_ENTRY_ALLOWED\"\n\nelif short_entry_allowed and not long_entry_allowed:\n    bias = \"SHORT\"\n    best_action = \"SHORT_ENTRY_ALLOWED\"\n\nelif long_entry_allowed and short_entry_allowed:\n    bias = \"CONFLICT\"\n    best_action = \"WAIT_CONFLICT\"\n\nelse:\n    if trend_aligned_long and m5_confirmed_long:\n        bias = \"LONG_WATCH\"\n        best_action = \"WAIT_FOR_LONG_CONFIRMATION\"\n\n    if trend_aligned_short and m5_confirmed_short:\n        bias = \"SHORT_WATCH\"\n        best_action = \"WAIT_FOR_SHORT_CONFIRMATION\"\n\n    if long_reversal_watch:\n        bias = \"LONG_REVERSAL_WATCH\"\n        best_action = \"WAIT_FOR_LONG_REVERSAL_CONFIRMATION\"\n\n    if short_reversal_watch:\n        bias = \"SHORT_REVERSAL_WATCH\"\n        best_action = \"WAIT_FOR_SHORT_REVERSAL_CONFIRMATION\"\n\nif bias == \"SHORT_WATCH\" and near_support:\n    bias = \"SHORT_BIAS_AT_SUPPORT\"\n    best_action = \"NO_SHORT_ENTRY_WAIT_FOR_BREAKDOWN_OR_RETEST\"\n    primary_block_reason = \"short_bias_but_price_too_close_to_support\"\n\nif bias == \"LONG_WATCH\" and near_resistance:\n    bias = \"LONG_BIAS_AT_RESISTANCE\"\n    best_action = \"NO_LONG_ENTRY_WAIT_FOR_BREAKOUT_OR_RETEST\"\n    primary_block_reason = \"long_bias_but_price_too_close_to_resistance\"\n\nif primary_block_reason == \"\":\n    if bias == \"SHORT_WATCH\" or bias == \"SHORT_BIAS_AT_SUPPORT\":\n        if len(short_block_reasons) > 0:\n            primary_block_reason = short_block_reasons[0]\n\n    if bias == \"LONG_WATCH\" or bias == \"LONG_BIAS_AT_RESISTANCE\":\n        if len(long_block_reasons) > 0:\n            primary_block_reason = long_block_reasons[0]\n\n# === RESULT ===\nresult = {\n    \"bias\": bias,\n    \"best_action\": best_action,\n    \"primary_block_reason\": primary_block_reason,\n\n    \"long\": {\n        \"entry_allowed\": long_entry_allowed,\n        \"entry_quality\": long_entry_quality,\n        \"sr_gate_passed\": sr_gate_long,\n        \"rsi_blocked\": long_rsi_blocked,\n        \"rsi_warning\": long_rsi_warning,\n        \"m5_confirmed\": m5_confirmed_long,\n        \"trend_aligned\": trend_aligned_long,\n        \"location_blocked\": long_location_blocked,\n        \"location_warning\": long_location_warning,\n        \"reversal_watch\": long_reversal_watch,\n        \"block_reasons\": long_block_reasons\n    },\n\n    \"short\": {\n        \"entry_allowed\": short_entry_allowed,\n        \"entry_quality\": short_entry_quality,\n        \"sr_gate_passed\": sr_gate_short,\n        \"rsi_blocked\": short_rsi_blocked,\n        \"rsi_warning\": short_rsi_warning,\n        \"m5_confirmed\": m5_confirmed_short,\n        \"trend_aligned\": trend_aligned_short,\n        \"location_blocked\": short_location_blocked,\n        \"location_warning\": short_location_warning,\n        \"reversal_watch\": short_reversal_watch,\n        \"block_reasons\": short_block_reasons\n    },\n\n    \"context\": {\n        \"strategy_aggressiveness\": strategy_aggressiveness,\n        \"direction\": direction,\n        \"ema_context\": ema_context,\n        \"ema_alignment\": ema_alignment,\n        \"trend_state\": trend_state,\n        \"continuation_direction\": continuation_direction,\n        \"reversal_candidate\": reversal_candidate,\n        \"entry_timeframe_flow\": entry_timeframe_flow,\n        \"entry_flow_for_gate\": entry_flow_for_gate,\n        \"rsi_value\": rsi_value,\n        \"rsi_level\": rsi_level,\n        \"rsi_direction\": rsi_direction,\n        \"long_rsi_conflict\": long_rsi_conflict,\n        \"short_rsi_conflict\": short_rsi_conflict,\n        \"near_support\": near_support,\n        \"near_resistance\": near_resistance,\n        \"distance_to_support_atr\": distance_to_support_atr,\n        \"distance_to_resistance_atr\": distance_to_resistance_atr\n    }\n}"
    }
  ]
}
