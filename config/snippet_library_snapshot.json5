      "description": "Calculation script — access transformed tool block outputs via the tool_outputs dict and build a result dict.",
      "code": "# All transformed tool block outputs are available via tool_outputs dict.\ncandles = tool_outputs.get(\"m5_recent\") or []\nindicator = tool_outputs.get(\"rsi_primary\") or {}\n\nresult = {\n    \"candle_count\": len(candles),\n    \"rsi_latest\": indicator.get(\"latest\"),\n    \"custom_flag\": True,\n}"
    },
    {
      "id": "snip_calc_iterate_candles",
      "name": "Iterate candles",
      "version": "1",
      "tags": "",
      "description": "Calculation script — iterate a candle list and extract high values. Useful as a starting point for custom calculations.",
      "code": "candles = tool_outputs.get(\"m5_recent\") or []\nhighs = [c[\"high\"] for c in candles if isinstance(c, dict) and \"high\" in c]\nresult = {\n    \"max_high\": max(highs) if highs else None,\n    \"candle_count\": len(candles),\n}"
    },
