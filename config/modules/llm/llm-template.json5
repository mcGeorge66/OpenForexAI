{
  // LLM module configuration
  // This file is managed by the module owner. The system only loads it by name.
  "adapter":         "anthropic|oanda|azure",
  "api_key":         "${LLM_API_KEY}",
  "model":           "${LLM_MODEL:-claude-opus-4-6}",
  "temperature":     0.1,
  "max_tokens":      1024,
  "timeout_seconds": 30,
  "retry_attempts":  3,
  "retry_base_delay": 1.0
}
