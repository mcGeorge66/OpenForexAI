{
  // OpenAI GPT LLM module configuration
  // This file is managed by the module owner. The system only loads it by name.
  "adapter": "openai",
  "base_url": "${LMS-BASE-URL}",
  "api_key": "${LMS-API-KEY}",
  "model": "${LMS-OSS-MODEL}",
  "retry_attempts": 3,
  "retry_base_delay": 1.0,
  "temperature": 0.1,
  "max_tokens": 4096
}
