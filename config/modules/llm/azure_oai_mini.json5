{
  "adapter": "azure",
  "api_key": "${OAI-AZURE-KEY}",
  "endpoint": "${OAI-AZURE-ENDPOINT}",
  "deployment": "${OAI-MINI-DEPLOYMENT}",
  "model": "${OAI-MINI-MODEL}",
  "api_version": "${OAI-MINI-API-VERSION}",
  "retry_attempts": 3,
  "retry_base_delay": 1.0,
  "temperature": 1.0,
  "max_tokens": 2048
}
