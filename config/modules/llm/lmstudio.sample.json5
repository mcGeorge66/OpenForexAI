{
  // Local LM Studio/OpenAI-compatible module configuration
  "adapter": "lmstudio",
  "base_url": "${LMS_BASE_URL:-http://127.0.0.1:1234/v1}",
  "api_key": "${LMS_API_KEY:-lm-studio}",
  "model": "${LMS_MODEL:-local-model}",
  "retry_attempts": 3,
  "retry_base_delay": 1.0,
  "temperature": 0.1,
  "max_tokens": 4096
}

