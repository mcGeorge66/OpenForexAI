{
  // Azure OpenAI LLM module configuration
  // This file is managed by the module owner. The system only loads it by name.
  "adapter": "azure",
  "api_key": "${OAI-AZURE-KEY}",
  "endpoint": "${OAI-AZURE-ENDPOINT}",
  "deployment": "${OAI-DEPLOYMENT}",
  "model": "${OAI-MODEL}",
  "api_version": "${OAI-API-VERSION}",
  "retry_attempts": 3,
  "retry_base_delay": 1.0,
  "timeout_seconds": 30,
  "sdk_max_retries": 0,
  "transcript_enabled": false,
  "transcript_path": "./logs/azure_llm_transcript.log",
  "temperature": 1.0,
  "max_tokens": 4096
}
