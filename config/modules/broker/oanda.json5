{
  // OANDA broker module configuration",
  // This file is managed by the module owner. The system only loads it by name.",
  "adapter":    "oanda",
  "short_name": "OAPR1",
  "api_url":    "${OAPR1-API-URL}",
  "api_key":    "${OAPR1-API-KEY}",
  "account_id": "${OAPR1-ACCOUNT-ID}",
  "practice":   true,
  "pair":       "EURUSD",
  "background_tasks": {
    "account_poll_interval_seconds": 60,
    "sync_interval_seconds": 60,
    "request_agent_reasoning": false
  }
}
