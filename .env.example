# ── LLM ─────────────────────────────────────────────────────────────────────
OPENFOREXAI_LLM__PROVIDER=anthropic          # anthropic | openai | lmstudio
OPENFOREXAI_LLM__MODEL=claude-opus-4-6
OPENFOREXAI_LLM__API_KEY=sk-ant-...

# OpenAI (only when provider=openai)
# OPENFOREXAI_LLM__PROVIDER=openai
# OPENFOREXAI_LLM__MODEL=gpt-4o
# OPENFOREXAI_LLM__API_KEY=sk-...

# LM Studio (only when provider=lmstudio)
# OPENFOREXAI_LLM__PROVIDER=lmstudio
# OPENFOREXAI_LLM__BASE_URL=http://localhost:1234
# OPENFOREXAI_LLM__MODEL=mistral-7b

# ── Broker ───────────────────────────────────────────────────────────────────
OPENFOREXAI_BROKER__NAME=oanda              # oanda | mt5
OPENFOREXAI_OANDA__API_KEY=...
OPENFOREXAI_OANDA__ACCOUNT_ID=...
OPENFOREXAI_OANDA__PRACTICE=true

# MT5 (Windows only, only when broker=mt5)
# OPENFOREXAI_MT5__LOGIN=12345678
# OPENFOREXAI_MT5__PASSWORD=...
# OPENFOREXAI_MT5__SERVER=Demo-Server

# ── Database ─────────────────────────────────────────────────────────────────
OPENFOREXAI_DATABASE__BACKEND=sqlite        # sqlite | postgresql
OPENFOREXAI_DATABASE__SQLITE_PATH=./data/openforexai.db

# PostgreSQL (only when backend=postgresql)
# OPENFOREXAI_DATABASE__BACKEND=postgresql
# OPENFOREXAI_DATABASE__DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/openforexai

# ── Risk ─────────────────────────────────────────────────────────────────────
OPENFOREXAI_RISK__MAX_RISK_PER_TRADE_PCT=1.0
OPENFOREXAI_RISK__MAX_TOTAL_EXPOSURE_PCT=5.0
OPENFOREXAI_RISK__MAX_DRAWDOWN_PCT=10.0
OPENFOREXAI_RISK__MAX_DAILY_LOSS_PCT=3.0
OPENFOREXAI_RISK__MAX_CORRELATION_THRESHOLD=0.7
OPENFOREXAI_RISK__MAX_OPEN_POSITIONS=6

# ── System ───────────────────────────────────────────────────────────────────
OPENFOREXAI_LOG_LEVEL=INFO
